# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# World App Configuration
NEXT_PUBLIC_WORLD_APP_ID=your-world-app-id
WORLD_APP_SECRET=your-world-app-secret

# Boost Payment Configuration
NEXT_PUBLIC_BOOST_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:54322/postgres"

# OpenAI (optionnel pour génération de contenu)
OPENAI_API_KEY=your-openai-api-key

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

